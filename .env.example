# Dragon Pet AI - Environment Variables Example
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# Do NOT commit real API keys to version control.

# ── Memory System ─────────────────────────────────────────
# Backend global gate for memory-aware chat (Phase 3 — implemented)
# Set to true to enable the memory injection pipeline.
# Default: false (safe — no memory injection without explicit opt-in)
MEMORY_INJECTION_ENABLED=false

# ── LLM Provider (Phase 4 — real provider not yet implemented) ─
#
# SAFETY RULES:
#   - LLM_API_KEY is backend-only. Never expose to frontend code.
#   - Never commit a real API key to version control.
#   - Never log the LLM_API_KEY value. Never include it in responses.
#   - Real provider adapter exists behind feature flags in TASK-035.
#
# Master switch. false = MockProvider always (safe default).
LLM_PROVIDER_ENABLED=false
#
# /chat switch. false = existing mock chat flow always (safe default).
# Must be true before /chat may call the LLM adapter.
LLM_CHAT_ENABLED=false
#
# Which real provider to use when enabled.
# Allowed values: mock, openai, anthropic
# Unknown values fall back to MockProvider + non-sensitive warning.
LLM_PROVIDER_NAME=mock
#
# API key for the active real provider.
# Leave blank if using mock provider (default).
# Backend environment only — never sent to frontend.
LLM_API_KEY=
#
# Optional. Provider-specific model identifier.
# Examples: gpt-4o, claude-opus-4-6
# Leave blank to use provider default.
LLM_MODEL=
#
# Real provider request timeout in seconds. Valid range: 1-120.
LLM_TIMEOUT_SECONDS=30
#
# If true, real provider failure falls back to MockProvider.
# If false, real provider failure returns canonical safe fallback text.
LLM_FALLBACK_TO_MOCK=true

# ── Application ───────────────────────────────────────────
# APP_ENV=development
# APP_PORT=3000

# ── Backend ───────────────────────────────────────────────
# BACKEND_URL=http://localhost:8000
